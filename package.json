{
  "name": "aireview",
  "displayName": "AI Review Router",
  "description": "Collect review comments from Git changes and hand them off to Codex or GitHub Copilot Chat.",
  "version": "0.0.1",
  "publisher": "aaskhan",
  "private": true,
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "https://github.com/aasimkhan30/aireview.git"
  },
  "engines": {
    "vscode": "^1.92.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:aireview.openReviewPanel",
    "onView:aireview.reviewView"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "aireview.openReviewPanel",
        "title": "AI Review: Open Review View"
      }
    ],
    "viewsContainers": {
      "secondarySidebar": [
        {
          "id": "aireview",
          "title": "AI Review",
          "icon": "$(comment-discussion)"
        }
      ]
    },
    "views": {
      "aireview": [
        {
          "type": "webview",
          "id": "aireview.reviewView",
          "name": "Review Notes"
        }
      ]
    }
  },
  "scripts": {
    "check": "npm run format:check && npm run lint && npm test && npm run package:check",
    "check-types": "tsc --noEmit",
    "compile": "npm run check-types && node esbuild.js",
    "compile:production": "npm run check-types && node esbuild.js --production",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint . --max-warnings 0",
    "test": "npm run test:unit && npm run test:integration",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:integration": "npm run compile:production && node scripts/run-integration-tests.mjs",
    "package:check": "vsce ls",
    "watch": "node esbuild.js --watch",
    "package": "vsce package",
    "vscode:prepublish": "npm run compile:production"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^20.14.10",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/vscode": "^1.92.0",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^2.31.1",
    "esbuild": "^0.23.0",
    "eslint": "^10.6.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.7.0",
    "prettier": "^3.9.4",
    "typescript": "^5.5.4",
    "typescript-eslint": "^8.63.0",
    "vitest": "^4.1.10"
  },
  "dependencies": {
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.21.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwind-merge": "^3.6.0",
    "vscode-jsonrpc": "^9.0.0"
  }
}
