{
  "name": "request-changes",
  "displayName": "Request Changes",
  "description": "Review agent-written code like a pull request and send requested changes back through MCP.",
  "icon": "media/icon.png",
  "galleryBanner": {
    "color": "#111C6C",
    "theme": "dark"
  },
  "version": "0.0.2",
  "publisher": "aasimkhan30",
  "private": true,
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "https://github.com/aasimkhan30/aireview.git"
  },
  "engines": {
    "vscode": "^1.125.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onCommand:requestchanges.openReviewPanel",
    "onCommand:requestchanges.addReviewComment",
    "onCommand:requestchanges.openSettings",
    "onLanguageModelTool:requestchanges",
    "onView:requestchanges.reviewView"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "title": "Request Changes",
      "properties": {
        "requestchanges.defaultOverallInstructions": {
          "type": "string",
          "default": "",
          "scope": "resource",
          "editPresentation": "multilineText",
          "markdownDescription": "Default instructions included whenever an agent addresses your review comments. A workspace value overrides the user value."
        }
      }
    },
    "mcpServerDefinitionProviders": [
      {
        "id": "requestchanges.mcpProvider",
        "label": "Request Changes"
      }
    ],
    "languageModelTools": [
      {
        "name": "requestchanges",
        "displayName": "Request Changes",
        "userDescription": "Read open review comments for agent-written code.",
        "modelDescription": "Read open review comments and overall instructions from Request Changes. Use only when the user explicitly asks for Request Changes or references #requestchanges. After addressing comments, summarize each individual comment and whether it was addressed or blocked.",
        "inputSchema": {
          "type": "object",
          "properties": {},
          "additionalProperties": false
        }
      }
    ],
    "commands": [
      {
        "command": "requestchanges.openReviewPanel",
        "title": "Request Changes: Open Review Comments"
      },
      {
        "command": "requestchanges.addReviewComment",
        "title": "Request Changes: Add Review Comment to Selection",
        "icon": "$(comment-add)"
      },
      {
        "command": "requestchanges.openSettings",
        "title": "Request Changes: Open Settings",
        "icon": "$(gear)"
      },
      {
        "command": "requestchanges.comment.create",
        "title": "Add review comment"
      },
      {
        "command": "requestchanges.comment.edit",
        "title": "Edit",
        "icon": "$(edit)"
      },
      {
        "command": "requestchanges.comment.save",
        "title": "Save"
      },
      {
        "command": "requestchanges.comment.cancelEdit",
        "title": "Cancel"
      },
      {
        "command": "requestchanges.comment.delete",
        "title": "Delete",
        "icon": "$(trash)"
      },
      {
        "command": "requestchanges.comment.resolve",
        "title": "Resolve",
        "icon": "$(check)"
      },
      {
        "command": "requestchanges.comment.reopen",
        "title": "Reopen",
        "icon": "$(history)"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "requestchanges.comment.create",
          "when": "false"
        },
        {
          "command": "requestchanges.comment.edit",
          "when": "false"
        },
        {
          "command": "requestchanges.comment.save",
          "when": "false"
        },
        {
          "command": "requestchanges.comment.cancelEdit",
          "when": "false"
        },
        {
          "command": "requestchanges.comment.delete",
          "when": "false"
        },
        {
          "command": "requestchanges.comment.resolve",
          "when": "false"
        },
        {
          "command": "requestchanges.comment.reopen",
          "when": "false"
        }
      ],
      "editor/context": [
        {
          "command": "requestchanges.addReviewComment",
          "group": "navigation@20",
          "when": "editorTextFocus && editorHasSelection"
        }
      ],
      "view/title": [
        {
          "command": "requestchanges.addReviewComment",
          "group": "navigation",
          "when": "view == requestchanges.reviewView"
        },
        {
          "command": "requestchanges.openSettings",
          "group": "navigation@2",
          "when": "view == requestchanges.reviewView"
        }
      ],
      "comments/commentThread/context": [
        {
          "command": "requestchanges.comment.create",
          "group": "inline",
          "when": "commentController == requestchanges.comments && commentThreadIsEmpty"
        }
      ],
      "comments/commentThread/title": [
        {
          "command": "requestchanges.comment.resolve",
          "group": "navigation@1",
          "when": "commentController == requestchanges.comments && commentThread == requestchanges.unresolved"
        },
        {
          "command": "requestchanges.comment.reopen",
          "group": "navigation@1",
          "when": "commentController == requestchanges.comments && commentThread == requestchanges.resolved"
        },
        {
          "command": "requestchanges.comment.delete",
          "group": "navigation@2",
          "when": "commentController == requestchanges.comments && !commentThreadIsEmpty"
        }
      ],
      "comments/comment/title": [
        {
          "command": "requestchanges.comment.edit",
          "group": "navigation@1",
          "when": "commentController == requestchanges.comments && comment == requestchanges.note"
        },
        {
          "command": "requestchanges.comment.delete",
          "group": "navigation@2",
          "when": "commentController == requestchanges.comments && comment == requestchanges.note"
        }
      ],
      "comments/comment/context": [
        {
          "command": "requestchanges.comment.cancelEdit",
          "group": "inline@1",
          "when": "commentController == requestchanges.comments && comment == requestchanges.note"
        },
        {
          "command": "requestchanges.comment.save",
          "group": "inline@2",
          "when": "commentController == requestchanges.comments && comment == requestchanges.note"
        }
      ]
    },
    "viewsContainers": {
      "secondarySidebar": [
        {
          "id": "requestchanges",
          "title": "Request Changes",
          "icon": "$(comment-discussion)"
        }
      ]
    },
    "views": {
      "requestchanges": [
        {
          "type": "webview",
          "id": "requestchanges.reviewView",
          "name": "Review Comments"
        }
      ]
    }
  },
  "scripts": {
    "check": "npm run format:check && npm run lint && npm test && npm run package:check",
    "check-types": "tsc --noEmit",
    "compile": "npm run check-types && node esbuild.js",
    "compile:production": "npm run check-types && node esbuild.js --production",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint . --max-warnings 0",
    "test": "npm run test:unit && npm run test:integration",
    "test:unit": "vitest run && npm run test:release-version",
    "test:release-version": "node --test scripts/release-version.test.mjs",
    "test:unit:watch": "vitest",
    "test:integration": "npm run compile:production && node test/mcp/index.cjs && node scripts/run-integration-tests.mjs",
    "package:check": "node scripts/check-package-contents.mjs",
    "watch": "node esbuild.js --watch",
    "package": "vsce package",
    "vscode:prepublish": "npm run compile:production"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.1.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/vscode": "^1.125.0",
    "@vscode/test-electron": "^3.0.0",
    "@vscode/vsce": "^3.9.2",
    "esbuild": "^0.28.1",
    "eslint": "^10.6.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.7.0",
    "prettier": "^3.9.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.63.0",
    "vitest": "^4.1.10"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.23.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwind-merge": "^3.6.0",
    "vscode-jsonrpc": "^9.0.1",
    "zod": "^4.4.3"
  }
}
